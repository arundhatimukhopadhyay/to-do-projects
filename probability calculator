import copy
import random

class Hat:
    def __init__(self, **kwargs):
        # Convert the keyword arguments into a list of ball colors
        self.contents = []
        for color, count in kwargs.items():
            self.contents.extend([color] * count)
            
    def draw(self, amount):
        # If the requested draw amount exceeds total balls, return all balls
        if amount >= len(self.contents):
            drawn_balls = self.contents.copy()
            self.contents.clear()
            return drawn_balls
        
        # Randomly draw balls without replacement
        drawn_balls = []
        for _ in range(amount):
            index = random.randrange(len(self.contents))
            drawn_balls.append(self.contents.pop(index))
        return drawn_balls

def experiment(hat, expected_balls, num_balls_drawn, num_experiments):
    success_count = 0
    
    for _ in range(num_experiments):
        # Deep copy ensures the original hat remains unmodified between trials
        hat_copy = copy.deepcopy(hat)
        drawn = hat_copy.draw(num_balls_drawn)
        
        # Tally the results of the draw
        drawn_counts = {}
        for ball in drawn:
            drawn_counts[ball] = drawn_counts.get(ball, 0) + 1
            
        # Verify if the drawn balls meet or exceed the expected target
        success = True
        for color, count in expected_balls.items():
            if drawn_counts.get(color, 0) < count:
                success = False
                break
                
        if success:
            success_count += 1
            
    # Calculate the final approximate probability
    return success_count / num_experiments
